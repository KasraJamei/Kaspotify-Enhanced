<?xml version="1.0" encoding="utf-8"?>
<!--
  Data backup/transfer rules (Android 12+). Covers both cloud backup (restored on reinstall) and
  device-to-device transfer, including the Room database so playlists, favorites, play counts and
  search history follow the user.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="." />
        <include domain="sharedpref" path="." />
        <include domain="file" path="." />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="." />
        <include domain="sharedpref" path="." />
        <include domain="file" path="." />
    </device-transfer>
</data-extraction-rules>
